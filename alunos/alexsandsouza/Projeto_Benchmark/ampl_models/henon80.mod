# Calculate an ending point on the other side of the barrier
for {iter in 1..10} {
  let {b1 in 0..BREAK+1, n in N} u[b1,n] := (1 - b1/(BREAK+1))*US[n] + (b1/(BREAK+1))*UE[n];

  if (energy[BREAK+1] < 0) then break;
  let {n in N} UE[n] := 2*UE[n];
}

# Backtrack to the barrier to get a better representation
let {n in N} UBAR[n] := US[n];
for {iter in 1..10} {
  let {b1 in 0..BREAK+1, n in N} u[b1,n] := (1 - b1/(BREAK+1))*UBAR[n] + (b1/(BREAK+1))*UE[n];

  let EBAR := max{b1 in 0..BREAK+1 : energy[b1] < 0.0} energy[b1];
  let BBAR := min{b1 in 0..BREAK+1 : energy[b1] = EBAR} b1;
  let {n in N} UBAR[n] := u[BBAR-1, n];
  let {n in N} UE[n] := u[BBAR, n];
}

let {b1 in 0..BREAK+1, n in N} u[b1,n] := (1 - b1/(BREAK+1))*US[n] + (b1/(BREAK+1))*UE[n];
let z := max{b1 in 0..BREAK+1} energy[b1];


